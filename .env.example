# Payment Security
PAYMENT_WEBHOOK_SECRET=""

# Stripe Configuration
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Paddle Billing (platform subscription billing for tenants)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=""   # Client token from Paddle dashboard → Authentication
PADDLE_API_KEY=""                    # API key from Paddle dashboard → Server-side API calls
PADDLE_WEBHOOK_SECRET=""             # Webhook secret from Paddle dashboard → Signature verification
NEXT_PUBLIC_PADDLE_ENVIRONMENT=""    # "sandbox" | "production" (default: sandbox)

# Email for payment notifications
PAYMENT_NOTIFICATION_EMAIL=""

# Communication Integrations
# Mailgun Email Service
MAILGUN_API_KEY=""
MAILGUN_DOMAIN=""
MAILGUN_FROM_EMAIL="noreply@yourdomain.com"

# Twilio SMS/Voice
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# WhatsApp Business API
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""

# SMS/Email Service Priority
ENABLE_MAILGUN="false"
ENABLE_TWILIO_SMS="false"
ENABLE_WHATSAPP="false"
DEFAULT_EMAIL_PROVIDER="internal" # internal, mailgun
DEFAULT_SMS_PROVIDER="internal" # internal, twilio

# Social Media OAuth Configuration
# Facebook/Instagram OAuth (Meta Developer App)
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Google OAuth (for YouTube)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Platform-Level Social Media Accounts (SUPER_ADMIN only)
# These are for Khesed-Tek's own marketing accounts
PLATFORM_FB_PAGE_ID=""
PLATFORM_FB_ACCESS_TOKEN=""
PLATFORM_IG_ACCOUNT_ID=""
PLATFORM_YT_CHANNEL_ID=""
PLATFORM_YT_ACCESS_TOKEN=""

# Social Media Security
SOCIAL_MEDIA_ENCRYPTION_KEY=""

# ─────────────────────────────────────────────
# AI Ministry Agents (feature/ai-ministry-agents)
# ─────────────────────────────────────────────

# Anthropic Claude — required by Agent 1 (Sermon Antiphony) and Agent 4 (Prayer Watchman)
# Generate at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=""

# Master switch — set to "true" to allow individual agent flags to take effect
ENABLE_AI_MINISTRY_AGENTS="false"

# Agent 1: Sermon Antiphony Engine
# Analyzes sermons for cultural blind spots and unresolved tensions
ENABLE_SERMON_ANTIPHONY="false"

# Agent 2: Spiritual Triage — Warm Handoff Protocol
# Detects distress keywords in prayer/contact forms and routes to human pastor
ENABLE_SPIRITUAL_TRIAGE="false"
# Comma-separated keywords (fallback if none stored in DB for the church)
# Example: TRIAGE_KEYWORDS=suicidio,me quiero morir,no quiero vivir,crisis,abuso,violencia
TRIAGE_KEYWORDS=""

# Agent 3: Wheat & Chaff Content Filter
# Transforms sermon analysis (Agent 1 must run first) into formation-minded social content
ENABLE_CONTENT_FILTER="false"

# Agent 4: Prayer Watchman
# Extracts dated events from prayer requests and schedules care touchpoints via WhatsApp
ENABLE_PRAYER_WATCHMAN="false"
# Hours after event to send follow-up message (default: 2 — matched in cron logic)
PRAYER_WATCHMAN_FOLLOWUP_HOURS="2"

# Agent 5: Shepherd's Log
# Surfaces at-risk and absent members for weekly pastoral review
ENABLE_SHEPHERDS_LOG="false"
# Cache TTL in hours (default: 168 = 1 week, refreshed by Monday 6 AM cron)
SHEPHERDS_LOG_REFRESH_HOURS="168"

# Phase 2 Agents (6–11)

# Agent 6: Leadership Pipeline
# Tracks member progression through leadership development stages
ENABLE_LEADERSHIP_PIPELINE="false"

# Agent 7: Burnout Sentinel
# Monitors over-serving volunteers and alerts leaders before burnout
ENABLE_BURNOUT_SENTINEL="false"

# Agent 8: Visitor Conversion Coach
# Analyzes visitor return patterns and generates pastoral nudges
ENABLE_VISITOR_CONVERSION="false"

# Agent 9: Generosity Journey
# Frames giving milestones as discipleship data (not revenue)
ENABLE_GENEROSITY_COACH="false"

# Agent 10: Small Group Health Monitor
# Scores group health monthly and notifies leaders of at-risk groups
ENABLE_SMALL_GROUP_MONITOR="false"

# Agent 11: Church Health Synthesizer (Board Report)
# Generates monthly narrative board report via Claude AI
ENABLE_BOARD_REPORT="false"

# Cron job authentication — required by all three cron routes
# Generate: openssl rand -hex 32
CRON_SECRET=""
