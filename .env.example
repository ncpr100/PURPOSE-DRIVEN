
# Database
DATABASE_URL="postgresql://..."

# Redis Cache Configuration (Performance Optimization)
REDIS_HOST="localhost"
REDIS_PORT="6379" 
REDIS_PASSWORD=""
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# AbacusAI
ABACUSAI_API_KEY=""

# Colombian Payment Gateways
# PSE (Pagos Seguros en Línea)
PSE_MERCHANT_ID=""
PSE_API_KEY=""
PSE_TEST_MODE="true"
PSE_RETURN_URL="https://yourdomain.com/api/payments/pse/return"
PSE_WEBHOOK_URL="https://yourdomain.com/api/payments/pse/webhook"

# Nequi
NEQUI_CLIENT_ID=""
NEQUI_CLIENT_SECRET=""
NEQUI_API_URL="https://api.nequi.com"
NEQUI_TEST_MODE="true"

# Daviplata  
DAVIPLATA_MERCHANT_ID=""
DAVIPLATA_API_KEY=""
DAVIPLATA_TEST_MODE="true"

# Payment Security
PAYMENT_WEBHOOK_SECRET=""

# Stripe Configuration
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Paddle Billing (platform subscription billing for tenants)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=""   # Client token from Paddle dashboard → Authentication
PADDLE_API_KEY=""                    # API key from Paddle dashboard → Server-side API calls
PADDLE_WEBHOOK_SECRET=""             # Webhook secret from Paddle dashboard → Signature verification
NEXT_PUBLIC_PADDLE_ENVIRONMENT=""    # "sandbox" | "production" (default: sandbox)

# Email for payment notifications
PAYMENT_NOTIFICATION_EMAIL=""

# Communication Integrations
# Mailgun Email Service
MAILGUN_API_KEY=""
MAILGUN_DOMAIN=""
MAILGUN_FROM_EMAIL="noreply@yourdomain.com"

# Twilio SMS/Voice
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# WhatsApp Business API
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""

# SMS/Email Service Priority
ENABLE_MAILGUN="false"
ENABLE_TWILIO_SMS="false"
ENABLE_WHATSAPP="false"
DEFAULT_EMAIL_PROVIDER="internal" # internal, mailgun
DEFAULT_SMS_PROVIDER="internal" # internal, twilio

