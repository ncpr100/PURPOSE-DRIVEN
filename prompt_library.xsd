<?xml version="1.0" encoding="UTF-8"?>
<!--
  prompt_library.xsd
  XSD Schema for KHESED-TEK Prompt Library.

  IMPORTANT: Use EITHER the DTD (<!DOCTYPE ...>) OR this XSD for validation —
  not both in the same workflow. XSD provides richer constraints.

  To validate with xmllint:
    xmllint [schema prompt_library.xsd] [noout] prompt_library_nodt.xml
  (Use a copy of the XML file without the <!DOCTYPE> line for XSD validation.)

  To validate with Python lxml:
    See extract_prompt.py [validate] flag.
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified">

  <!-- ============================================================
       Root element
  ============================================================ -->
  <xs:element name="prompt_library">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="project" type="ProjectType" minOccurs="1" maxOccurs="unbounded"/>
      </xs:sequence>
    </xs:complexType>

    <!-- Enforce globally unique prompt IDs across all projects -->
    <xs:unique name="UniquePromptId">
      <xs:selector xpath="project/prompt"/>
      <xs:field    xpath="@id"/>
    </xs:unique>
  </xs:element>

  <!-- ============================================================
       Project type
  ============================================================ -->
  <xs:complexType name="ProjectType">
    <xs:sequence>
      <xs:element name="prompt" type="PromptType" minOccurs="1" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="name" type="xs:string" use="required"/>
  </xs:complexType>

  <!-- ============================================================
       Prompt type
       id: xs:string (not xs:ID) to avoid strict NCName restrictions
           and cross-parser inconsistencies; uniqueness is enforced
           by the xs:unique constraint on prompt_library above.
  ============================================================ -->
  <xs:complexType name="PromptType">
    <xs:all>
      <xs:element name="context"            type="xs:string"/>
      <xs:element name="instructions"       type="xs:string"/>
      <xs:element name="output_requirements" type="xs:string"/>
    </xs:all>
    <xs:attribute name="id" type="PromptIdType" use="required"/>
  </xs:complexType>

  <!-- ============================================================
       ID format constraint:
       Must start with a letter or underscore, followed by
       letters, digits, hyphens, or underscores.
       Examples: cms_universal, marketing_bug_fixing
  ============================================================ -->
  <xs:simpleType name="PromptIdType">
    <xs:restriction base="xs:string">
      <xs:pattern value="[a-zA-Z_][a-zA-Z0-9_\-]*"/>
      <xs:minLength value="3"/>
    </xs:restriction>
  </xs:simpleType>

</xs:schema>
